# Web UI login credentials (protects the dashboard from public access)
# REQUIRED — leave UI_PASSWORD blank and the login page will reject all attempts
UI_USERNAME=admin
UI_PASSWORD=

# Which VoIP provider to use: twilio, signalwire, or telnyx
VOICE_PROVIDER=twilio

# Twilio credentials — get these from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# SignalWire credentials — get these from your Space's dashboard (API Credentials)
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_AUTH_TOKEN=
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com
# Webhook signature validation uses the Space's Signing Key (PSK_...), a
# separate credential from the PT... API token above — also under API Credentials.
SIGNALWIRE_SIGNING_KEY=
SIGNALWIRE_FROM_NUMBER=+1XXXXXXXXXX

# Telnyx credentials — get these from portal.telnyx.com (Account Settings -> API Keys)
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+1XXXXXXXXXX
# Call Control Application ("Connection") ID — Voice -> Call Control Applications.
# Its webhook URL must point to https://your-public-url/webhook/telnyx
TELNYX_CONNECTION_ID=
# Public key (base64) from portal.telnyx.com -> Account Settings -> Public Key,
# used to verify inbound webhook signatures (Ed25519). Leave blank to skip
# signature validation (logged as a warning each time).
TELNYX_PUBLIC_KEY=
# Optional — required only if you want outbound SMS via Telnyx
TELNYX_MESSAGING_PROFILE_ID=

# Minimum seconds between any two outbound calls placed by this app — a
# safety net against the voice provider's outbound call rate limit.
MIN_CALL_SPACING_SECONDS=2

# Flask
FLASK_SECRET_KEY=change-this-to-a-long-random-string
PORT=5000

# Public URL for Twilio webhooks.
# Leave blank to auto-detect (tries ngrok if behind NAT).
# Set to your server's public address if you have one: http://192.168.1.x:5000
PUBLIC_URL=

# Required if using ngrok (free account token from ngrok.com)
NGROK_AUTH_TOKEN=

# Default minutes between reminder retry attempts (per-schedule setting overrides this)
DEFAULT_ATTEMPT_INTERVAL_MINUTES=10

# Key the client must press on a wellness call to confirm they are okay (default: 1)
REQUIRED_KEYPRESS=1

# Minutes to wait after calling all emergency contacts before starting the next cycle (default: 5)
EMERGENCY_CONTACT_INTERVAL_MINUTES=5

# Text-to-speech voice for all synthesised speech (fallback messages, wellness/emergency prompts)
# Twilio options: Polly.Joanna-Neural, Polly.Matthew-Neural, Polly.Amy-Neural, Polly.Joanna, alice
TWILIO_VOICE=Polly.Joanna-Neural

# SignalWire uses a different voice set than Twilio's Polly.*-Neural names.
# Defaults to "woman" if unset. Check SignalWire's <Say voice="..."> docs for other options.
SIGNALWIRE_VOICE=woman

# Telnyx TTS voice for <speak> commands (e.g. "female", "male", or a specific
# provider voice ID per Telnyx's Call Control docs)
TELNYX_VOICE=female

# Optional SSL certs for HTTPS direct access (not needed when using ngrok)
CERT_FILE=
KEY_FILE=
